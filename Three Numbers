Time Limit: 0.5 sec
Memory: 256 MB

Description
Given two numbers K and S. Determine how many different values of X, Y, and Z such that (0 ≤ X, Y, Z ≤ K) and X + Y + Z = S.

Input Format
Only one line containing two numbers K and S.

Output Format
Print the answer required above.

Constraints
0 ≤ K ≤ 3000
0 ≤ S ≤ 3K

Sample Input 1
2 1

Sample Output 1
3

Sample Input 2
9 4

Sample Output 2
15

Note

Sample Input 1:
When K = 2 and S = 1, the possible values of (X, Y, Z) are:

(1, 0, 0)
(0, 1, 0)
(0, 0, 1)

Thus, there are 3 solutions.

Sample Input 2:
When K = 9 and S = 4, the possible values of (X, Y, Z) are:

(0, 0, 4)
(0, 1, 3)
(0, 2, 2)
(0, 3, 1)
(0, 4, 0)
(1, 0, 3)
(1, 1, 2)
(1, 2, 1)
(1, 3, 0)
(2, 0, 2)
(2, 1, 1)
(2, 2, 0)
(3, 0, 1)
(3, 1, 0)
(4, 0, 0)

Thus, there are 15 solutions.



#include <bits/stdc++.h>
using namespace std;
// O(K) time
// O(1) space

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(0);
    cout.tie(0);

    int k, s;
    cin >> k >> s;
    int ans = 0;
    // to ensure s-z is below 2*k
    int st = max(0, s - 2 * k);
    // to ensure s-z is greater than equal to 0
    int end = min(k, s);
    for (int z = st; z <= end; z++) // loop for all possible values of x
    {
        int rem = s - z;
        if (rem > k)
            ans += (2 * k - rem + 1);
        else
            ans += (rem + 1);
    }
    cout << ans << "\n";

    return 0;
}

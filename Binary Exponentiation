//for TC = O(b)
long long power(long long a, long long b) {
    long long ans = 1;

    for(int i = 0; i < b; i++) {
        ans *= a;
    }

    return ans;
}


//binaryexpontiaons code 
//TC : O(log b) 

#include <bits/stdc++.h>
using namespace std;

typedef long long ll;

ll binpow(ll a, ll b, ll mod) {

    if (b == 0)
        return 1;

    if (b % 2 == 1) {
        return (a % mod * binpow(a, b - 1, mod) % mod) % mod;
    }
    else {
        ll temp = binpow(a, b / 2, mod);
        return (temp * temp) % mod;
    }
}

void solve() {

    ll a = 2;
    ll b = 10;
    ll mod = 1000000007;

    cout << binpow(a, b, mod) << "\n";
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}

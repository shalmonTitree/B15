--------------------------------------------------------------------------------------------------------------------------------

Time Complexity: O(N)
Space Complexity: O(1)

#include <iostream>
using namespace std;

long long sumOfAllSubarrays(int arr[], int N) {
    long long totalSum = 0;

    for (int i = 0; i < N; i++) {
        totalSum += 1LL * arr[i] * (i + 1) * (N - i);
    }

    return totalSum;
}

int main() {
    int arr[] = {1, 2, 3};
    int N = sizeof(arr) / sizeof(arr[0]);

    cout << "Sum of all subarrays = "
         << sumOfAllSubarrays(arr, N) << endl;

    return 0;
}

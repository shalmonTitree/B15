Note

Compute a prefix-sum array modulo 10^9 + 7, where:

prefix[i] = (A1 + A2 + ⋯ + Ai) % (10^9 + 7)

For a query L, R, the answer is:

prefix[R] − prefix[L−1]

adjusted to be within [0, 10^9 + 6] by adding 10^9 + 7 if the result is negative.



#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
#define endl "\n"   // optional, better to avoid redefining endl
const long long MOD = 1000000007LL;

void solve() {
    ll n,q;
    cin>>n>>q;
    vector<ll>v(n);
    for(int i = 0; i < n; i++)
    {
        cin>>v[i];
    }
    vector<ll>prefix(n);
    prefix[0] = v[0];

    for(int i = 1; i < n; i++)
    {
        prefix[i] = (prefix[i-1] + v[i]);
    }
    ll sum;
    while(q--)
    {
        int l,r;
        cin>>l>>r;
        l--;
        r--;
        if(l == 0)
        {
            sum = prefix[r];
        }
        else
        {
             sum = prefix[r] - prefix[l - 1];
        }
        cout << ((sum % MOD) + MOD) % MOD << endl;
    }
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t = 1;
    //cin >> t;
    while (t--) {
        solve();
    }

    return 0;
}

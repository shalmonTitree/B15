#include <bits/stdc++.h>
using namespace std;

typedef long long ll;
const ll MOD = 1000000007;

ll modpow(ll a, ll b)
{
    ll res = 1;
    a %= MOD;

    while (b)
    {
        if (b & 1)
            res = res * a % MOD;

        a = a * a % MOD;
        b >>= 1;
    }

    return res;
}

void solve()
{
    int n, q;
    ll K;
    cin >> n >> q >> K;

    vector<ll> a(n + 1);
    vector<ll> powK(n + 1);
    vector<ll> invPowK(n + 1);
    vector<ll> pref(n + 1, 0);

    powK[0] = 1;

    for (int i = 1; i <= n; i++)
        powK[i] = powK[i - 1] * K % MOD;

    for (int i = 0; i <= n; i++)
        invPowK[i] = modpow(powK[i], MOD - 2);

    for (int i = 1; i <= n; i++)
    {
        cin >> a[i];

        ll x = (a[i] % MOD + MOD) % MOD;

        pref[i] = (pref[i - 1] + x * powK[i]) % MOD;
    }

    while (q--)
    {
        int L, R;
        cin >> L >> R;

        ll sum = (pref[R] - pref[L - 1] + MOD) % MOD;

        ll ans = sum * invPowK[L] % MOD;

        cout << ans << '\n';
    }
}

int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    solve();

    return 0;
}

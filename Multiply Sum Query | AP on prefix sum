#include <bits/stdc++.h>
using namespace std;

typedef long long ll;
const ll MOD = 1000000007;

void solve()
{
    int n, q;
    cin >> n >> q;

    vector<ll> input(n + 1);
    vector<ll> pref(n + 1, 0);
    vector<ll> weighted(n + 1, 0);

    for (int i = 1; i <= n; i++)
    {
        cin >> input[i];

        ll x = (input[i] % MOD + MOD) % MOD;

        pref[i] = (pref[i - 1] + x) % MOD;
        weighted[i] = (weighted[i - 1] + x * i) % MOD;
    }

    while (q--)
    {
        int L, R;
        cin >> L >> R;

        ll sumA = (pref[R] - pref[L - 1] + MOD) % MOD;
        ll sumIA = (weighted[R] - weighted[L - 1] + MOD) % MOD;

        ll ans = (sumIA - 1LL * (L - 1) * sumA) % MOD;
        ans = (ans + MOD) % MOD;

        cout << ans << '\n';
    }
}

int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t = 1;
   // cin >> t;

    while (t--)
    {
        solve();
    }

    return 0;
}
